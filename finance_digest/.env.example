# Copy this to .env and fill in your values

# Free email API — sign up at resend.com, takes 2 minutes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Who receives the digest (already set to yours)
RECIPIENT_EMAIL=elmusharf@gmail.com

# Optional: official Korea semiconductor export data (free key at kosis.kr/openapi)
# Without this, the weekly digest falls back to news headlines only.
KOSIS_API_KEY=
